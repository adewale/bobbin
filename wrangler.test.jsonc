{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bobbin-test",
  "main": "src/index.tsx",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "TOPIC_EXTRACTOR_MODE": "naive"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bobbin-db",
      "database_id": "local"
    }
  ]
  // AI and Vectorize bindings intentionally omitted for tests —
  // they require Cloudflare auth which isn't available in CI
}
